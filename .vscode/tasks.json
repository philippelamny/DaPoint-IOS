    {
      "label": "Flutter: build APK (release, versioned)",
      "type": "shell",
      "command": "cd flutter && mkdir -p build/releases && VERSION=$(grep '^version:' pubspec.yaml | head -n 1 | cut -d ' ' -f2 | tr -d '\\r' | tr '+' '-') && TIMESTAMP=$(date +%Y%m%d-%H%M) && flutter build apk --release && cp build/app/outputs/flutter-apk/app-release.apk \"build/releases/da_point-${VERSION}-${TIMESTAMP}.apk\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
